---
import { getCollection, getEntry, render } from 'astro:content';
import VoteBadge from './VoteBadge.astro';
import SourceLinks from './SourceLinks.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import JusticeNames from './JusticeNames.astro';
import OutcomeDot from './OutcomeDot.astro';
import { dispositionLabel, t, type Lang } from '../i18n/ui';
import {
  formatDate,
  makeLeanResolver,
  slugOf,
  type DecisionEntry,
} from '../lib/decisions';

interface Props {
  entry: DecisionEntry;
  available: Lang[];
}
const { entry, available } = Astro.props;
const lang = entry.data.lang as Lang;
const s = t(lang);
const d = entry.data;
const slug = slugOf(entry);
const { Content } = await render(entry);

const metaParts = [formatDate(d.date, lang)];
if (d.term) metaParts.push(`${s.term} ${d.term}`);
if (d.docket) metaParts.push(`${s.docket} ${d.docket}`);

// Justice names ALWAYS come from the English entry, even on translated pages: the
// lean-dot resolver matches English surnames, so a localized name (e.g. "罗伯茨首席大法官")
// would silently swallow its colored dot. Sourcing the names from the canonical English
// sibling keeps the names — and the dots — consistent regardless of translation.
const enId = entry.id.replace(/\/[^/]+$/, '/en');
const enData =
  entry.data.lang === 'en'
    ? d
    : ((await getEntry('decisions', enId))?.data ?? d);

// Prefix each named justice with a dot colored by political lean.
const leanOf = makeLeanResolver(await getCollection('justices'));
const toItems = (names: string[]) =>
  names.map((name) => ({ name, lean: leanOf(name) }));
---

<article class="pt-8">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <a href="/" class="text-sm text-muted hover:text-ink">
      <span aria-hidden="true">←</span> <span>{s.backToDecisions}</span>
    </a>
    {
      available.length > 1 ? (
        <LanguageSwitcher
          slug={slug}
          current={lang}
          available={available}
          label={s.language}
        />
      ) : null
    }
  </div>

  <header class="mt-5">
    <div class="flex items-center gap-2.5">
      {d.outcomeLean ? <OutcomeDot outcome={d.outcomeLean} lang={lang} size="h-3 w-3" /> : null}
      <h1
        class="text-3xl font-bold leading-tight tracking-tight text-ink sm:text-4xl"
      >
        {d.caseName}
      </h1>
    </div>
    <p class="mt-2 text-sm text-muted">{metaParts.join(' · ')}</p>
    <div class="mt-4 flex flex-wrap items-center gap-2.5">
      <VoteBadge vote={d.vote} label={s.vote} />
      <span
        class="rounded-md border border-line bg-surface px-2 py-1 text-sm font-medium text-ink"
      >
        {dispositionLabel(d.disposition, lang)}
      </span>
      {
        d.topics.map((topic) => (
          <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-medium text-accent">
            {topic}
          </span>
        ))
      }
    </div>
  </header>

  {/* The outcome */}
  <section class="mt-8 rounded-2xl border border-line bg-surface p-6">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-faint">
      {s.outcome}
    </h2>
    <dl class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
          {s.prevailingParty}
        </dt>
        <dd class="mt-0.5 font-semibold text-ink">{d.winner}</dd>
      </div>
      <div>
        <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
          {s.losingParty}
        </dt>
        <dd class="mt-0.5 font-semibold text-ink">{d.loser}</dd>
      </div>
      <div>
        <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
          {s.disposition}
        </dt>
        <dd class="mt-0.5 font-medium text-ink">
          {dispositionLabel(d.disposition, lang)}
        </dd>
      </div>
      {
        d.lowerCourt ? (
          <div>
            <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
              {s.lowerCourt}
            </dt>
            <dd class="mt-0.5 font-medium text-ink">{d.lowerCourt}</dd>
          </div>
        ) : null
      }
    </dl>
    <div class="mt-4 border-t border-line pt-4">
      <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
        {s.held}
      </dt>
      <p class="mt-1 text-base text-ink">{d.holding}</p>
    </div>
  </section>

  {/* The opinions — the majority, then the dissent (when there is one) */}
  <section class="mt-8">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-faint">
      {s.majorityOpinion}
    </h2>
    <p class="mt-2 text-base leading-relaxed text-ink">
      {d.courtOpinionSummary}
    </p>
    {
      d.dissentSummary ? (
        <Fragment>
          <h2 class="mt-6 text-sm font-semibold uppercase tracking-wide text-faint">
            {s.dissentOpinion}
          </h2>
          <p class="mt-2 text-base leading-relaxed text-ink">
            {d.dissentSummary}
          </p>
        </Fragment>
      ) : null
    }
    <dl class="mt-4 flex flex-col gap-2 text-sm">
      <div class="flex gap-2">
        <dt class="w-28 shrink-0 pt-0.5 text-faint">{s.majority}</dt>
        <dd><JusticeNames items={toItems([enData.majorityAuthor])} lang={lang} /></dd>
      </div>
      {
        enData.joinedBy.length > 0 ? (
          <div class="flex gap-2">
            <dt class="w-28 shrink-0 pt-0.5 text-faint">{s.joinedBy}</dt>
            <dd>
              <JusticeNames items={toItems(enData.joinedBy)} lang={lang} />
            </dd>
          </div>
        ) : null
      }
      {
        enData.concurrences.length > 0 ? (
          <div class="flex gap-2">
            <dt class="w-28 shrink-0 pt-0.5 text-faint">{s.concurrence}</dt>
            <dd>
              <JusticeNames items={toItems(enData.concurrences)} lang={lang} />
            </dd>
          </div>
        ) : null
      }
      {
        enData.dissentBy.length > 0 ? (
          <div class="flex gap-2">
            <dt class="w-28 shrink-0 pt-0.5 text-faint">{s.dissent}</dt>
            <dd>
              <JusticeNames items={toItems(enData.dissentBy)} lang={lang} />
            </dd>
          </div>
        ) : null
      }
    </dl>
  </section>

  <SourceLinks sources={d.sources} heading={s.sources} />

  {/* Editorial — the point of the site */}
  <section class="mt-12 border-t-2 border-ink pt-8">
    <div class="flex items-baseline gap-3">
      <h2 class="text-2xl font-bold tracking-tight text-ink">{s.editorial}</h2>
      <span class="text-xs font-medium uppercase tracking-wide text-accent">
        {s.editorialNote}
      </span>
    </div>
    <div class="prose mt-5">
      <Content />
    </div>
  </section>
</article>
