---
import OutcomeDot from './OutcomeDot.astro';
import { t, type Lang } from '../i18n/ui';
import { formatDate, slugOf, type DecisionEntry } from '../lib/decisions';

interface Props {
  entry: DecisionEntry;
  lang?: Lang;
}
const { entry, lang = 'en' } = Astro.props;
const d = entry.data;
const slug = slugOf(entry);
---

<a
  href={`/decisions/${slug}`}
  class="block rounded-xl border border-line bg-white px-5 py-4 transition hover:border-ink/30 hover:shadow-sm"
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="flex min-w-0 items-center gap-2">
        {d.outcomeLean ? <OutcomeDot outcome={d.outcomeLean} lang={lang} /> : null}
        <h3 class="truncate font-semibold text-ink">{d.caseName}</h3>
      </div>
      <p class="mt-1 line-clamp-2 text-sm text-muted">{d.holding}</p>
    </div>
    <div class="shrink-0 text-right">
      <div class="font-semibold tabular-nums text-ink">{d.vote}</div>
      <div class="mt-1 text-xs text-faint">{formatDate(d.date, lang)}</div>
    </div>
  </div>
</a>
