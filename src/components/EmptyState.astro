---
interface Props {
  title: string;
  blurb?: string;
  date?: string;
}
const { title, blurb, date } = Astro.props;
---

<div
  class="rounded-2xl border border-dashed border-line bg-surface px-6 py-16 text-center"
>
  <p class="text-3xl" aria-hidden="true">⚖️</p>
  {
    date ? (
      <p class="mt-3 text-xs font-medium uppercase tracking-wide text-faint">
        {date}
      </p>
    ) : null
  }
  <h2 class="mt-1 text-lg font-semibold text-ink">{title}</h2>
  {blurb ? <p class="mx-auto mt-1 max-w-md text-sm text-muted">{blurb}</p> : null}
</div>
