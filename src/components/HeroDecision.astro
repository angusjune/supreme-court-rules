---
import VoteBadge from './VoteBadge.astro';
import OutcomeDot from './OutcomeDot.astro';
import { dispositionLabel, t, type Lang } from '../i18n/ui';
import { formatDate, slugOf, type DecisionEntry } from '../lib/decisions';

interface Props {
  entry: DecisionEntry;
  lang?: Lang;
}
const { entry, lang = 'en' } = Astro.props;
const s = t(lang);
const d = entry.data;
const slug = slugOf(entry);
const metaParts = [formatDate(d.date, lang)];
if (d.docket) metaParts.push(`${s.docket} ${d.docket}`);
---

<article
  class="rounded-3xl border border-line bg-white p-7 shadow-sm sm:p-9"
>
  <div
    class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-accent"
  >
    <span class="inline-block h-2 w-2 rounded-full bg-accent"></span>
    <span>{s.todaysDecision}</span>
  </div>

  <a href={`/decisions/${slug}`} class="group mt-3 flex items-center gap-2.5">
    {d.outcomeLean ? <OutcomeDot outcome={d.outcomeLean} lang={lang} size="h-3 w-3" /> : null}
    <h1
      class="text-3xl font-bold leading-tight tracking-tight text-ink transition-colors group-hover:text-accent sm:text-4xl"
    >
      {d.caseName}
    </h1>
  </a>
  <p class="mt-2 text-sm text-muted">{metaParts.join(' · ')}</p>

  <div class="mt-5 flex flex-wrap items-center gap-2.5">
    <VoteBadge vote={d.vote} label={s.vote} />
    <span
      class="rounded-md border border-line bg-surface px-2 py-1 text-sm font-medium text-ink"
    >
      {dispositionLabel(d.disposition, lang)}
    </span>
    {
      d.topics.map((topic) => (
        <span class="rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-medium text-accent">
          {topic}
        </span>
      ))
    }
  </div>

  <p class="mt-5 text-lg leading-relaxed text-ink">{d.holding}</p>

  <dl class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
    <div>
      <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
        {s.prevailingParty}
      </dt>
      <dd class="mt-0.5 font-medium text-ink">{d.winner}</dd>
    </div>
    <div>
      <dt class="text-[0.65rem] font-medium uppercase tracking-wide text-faint">
        {s.losingParty}
      </dt>
      <dd class="mt-0.5 font-medium text-ink">{d.loser}</dd>
    </div>
  </dl>

  <a
    href={`/decisions/${slug}`}
    class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-accent transition-all hover:gap-2"
  >
    <span>{s.readEditorial}</span>
    <span aria-hidden="true">→</span>
  </a>
</article>
