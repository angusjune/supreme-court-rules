---
import { t, type Lang } from '../i18n/ui';

interface Props {
  outcome: 'conservative' | 'liberal' | 'neutral';
  size?: string;
  lang?: Lang;
}
const { outcome, size = 'h-2.5 w-2.5', lang = 'en' } = Astro.props;
const s = t(lang);

const dotColor = {
  conservative: 'bg-conservative',
  liberal: 'bg-liberal',
  neutral: 'bg-centrist',
} as const;
const label = {
  conservative: s.winConservative,
  liberal: s.winLiberal,
  neutral: s.winNeutral,
}[outcome];
---

<span
  class={`inline-block shrink-0 rounded-full ${size} ${dotColor[outcome]}`}
  role="img"
  aria-label={label}
  title={label}></span>
