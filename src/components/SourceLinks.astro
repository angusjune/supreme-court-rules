---
interface Props {
  sources: { label: string; url: string }[];
  heading: string;
}
const { sources, heading } = Astro.props;
---

{
  sources.length > 0 ? (
    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-faint">
        {heading}
      </h2>
      <ul class="mt-2 flex flex-col gap-1.5">
        {sources.map((src) => (
          <li>
            <a
              href={src.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-accent underline underline-offset-2 hover:no-underline"
            >
              {src.label} ↗
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null
}
