---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeanBadge from '../../components/LeanBadge.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { DEFAULT_LANG, t } from '../../i18n/ui';
import { formatDate } from '../../lib/decisions';

export async function getStaticPaths() {
  const justices = await getCollection('justices');
  return justices.map((justice) => ({
    params: { id: justice.id },
    props: { justice },
  }));
}

const { justice } = Astro.props;
const j = justice.data;
const s = t(DEFAULT_LANG);
const { Content } = await render(justice);

// Optional opinionated editorial (separate collection, routine-updatable).
const editorial = await getEntry('justiceEditorials', justice.id);
const editorialRender = editorial ? await render(editorial) : null;
const EditorialContent = editorialRender?.Content;
---

<BaseLayout activeTab="justices" lang={DEFAULT_LANG} title={j.name}>
  <article class="pt-8">
    <a href="/justices" class="text-sm text-muted hover:text-ink">
      <span aria-hidden="true">←</span> <span>{s.navJustices}</span>
    </a>

    <header class="mt-4 flex items-start gap-5">
      <img
        src={j.photo}
        alt={j.name}
        width="120"
        height="150"
        class="h-36 w-28 shrink-0 rounded-xl bg-surface object-cover object-top"
      />
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-ink">{j.name}</h1>
        <p class="mt-1 text-sm text-muted">{j.role}</p>
        <div class="mt-2">
          <LeanBadge lean={j.lean} />
        </div>
        <p class="mt-3 text-sm text-muted">
          Appointed by {j.appointedBy}, confirmed {j.confirmedYear}.
        </p>
      </div>
    </header>

    <div class="prose mt-8">
      <Content />
    </div>

    {
      EditorialContent ? (
        <section class="mt-12 border-t-2 border-ink pt-8">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h2 class="text-2xl font-bold tracking-tight text-ink">{s.editorial}</h2>
            <span class="text-xs font-medium uppercase tracking-wide text-accent">
              Opinion — my take on the Justice
            </span>
          </div>
          {editorial?.data.thesis ? (
            <p class="mt-3 text-lg italic leading-relaxed text-muted">
              {editorial.data.thesis}
            </p>
          ) : null}
          {editorial?.data.updated ? (
            <p class="mt-1 text-xs text-faint">
              Updated {formatDate(editorial.data.updated, DEFAULT_LANG)}
            </p>
          ) : null}
          <div class="prose mt-5">
            <EditorialContent />
          </div>
        </section>
      ) : null
    }
  </article>
</BaseLayout>
